# ──  CopyCraft 本地开发 环境变量示例  ──────────────────────────────────────
#  复制本文件为 .env 后填你自己的值：cp .env.example .env  （已被 gitignore）
#  Windows PowerShell：$env:JWT_SECRET='xxx'; node --experimental-not needed-for-mysql server/index.js
#  Windows cmd  ：      set JWT_SECRET=xxx && node server/index.js
#  Git Bash：           JWT_SECRET=xxx npm run server

# ----------  鉴权  ----------
# JWT_SECRET       必填！HMAC-SHA256 token 签名密钥 + AES-256-GCM api_key 存储密钥根。
#                  请使用 >= 32 的随机字符串（例如命令行：openssl rand -hex 32）
JWT_SECRET=

# ----------  MySQL 8.0.30 (你的本机 3307 端口)  ----------
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=copycraft
# DB 自动建表策略：
#   WARM_UP=1（默认）启动时检查库连通性，不允许则报错
DB_INIT_BEFORE_BOOT=0      # 设为 1 时启动前先跑 db_init.sql（仅首次或改了 schema）

# ----------  验证码 / session  ----------
VERIFY_CODE_TTL=600          # 秒，默认 600
SESSION_TTL=2592000          # 秒，默认 30 天

# ──  DeepSeek （可选，配置后用"托管 Key"走后端代理；不配则前端直连）─────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
