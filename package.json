{
  "name": "copycraft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CopyCraft · 多平台文案适配分发工具 MVP",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:desktop": "tsc -b && vite build --mode desktop",
    "preview": "vite preview",
    "type-check": "tsc -b --noEmit",
    "server": "node server/index.js",
    "db:init": "node server/db_init.js",
    "dev:full": "concurrently \"npm:server\" \"npm:dev\"",
    "electron:dev": "ELECTRON_DEV=1 electron .",
    "electron:build": "npm run build:desktop && electron-builder --config electron-builder.yml --win --publish never"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "mysql2": "^3.22.5",
    "nodemailer": "^8.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.3"
  }
}
